# ── Notion ────────────────────────────────────────────────────────────────
# Token de l'intégration Notion (https://www.notion.so/my-integrations)
# L'intégration doit être partagée avec la base « 📢 Prospects webinaire ».
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base « 📢 Prospects webinaire » (CRM IPP) — déjà créée, ID fixe :
NOTION_SETTER_DB_ID=23fb927e-d71f-467e-aa9b-07e6c97c7522

# ── System.io (synchro des tags) ──────────────────────────────────────────
# Clé MCP System.io : Paramètres → Clés MCP → colonne « Jeton ».
# Sert à : poser les tags quand la setter agit (Résa call / Pas intéressé /
# Injoignable / Réinscrit) ET à alimenter la file depuis les tags présents/absents.
SYSTEMEIO_MCP_KEY=

# Synchro ENTRANTE automatique (System.io → Notion). Laisser à false pour
# piloter à la main via /api/sync/preview (aperçu) et /api/sync/run.
SYSTEMEIO_SYNC_ENABLED=false
SYSTEMEIO_SYNC_INTERVAL_MIN=10   # fréquence de la boucle (min) si activée
SYSTEMEIO_SYNC_WINDOW_DAYS=14    # ne synchronise que les inscrits des N derniers jours

# ── Calendly (optionnel) ──────────────────────────────────────────────────
# Calendly → Intégrations → Webhooks → Signing key. Si vide, signature non vérifiée.
CALENDLY_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
